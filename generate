# ====================== 后处理+保存 ======================
# 新增：1bit后处理，强制纯黑白像素风格
def palette_quantize(image):
    img = np.array(image.convert("L"))

    palette = np.array([0,255])

    idx = np.abs(img[:,:,None] - palette).argmin(axis=2)
    quant = palette[idx]

    quant = np.stack([quant]*3,axis=-1)

    return Image.fromarray(quant.astype(np.uint8))

