# 1bit纯度计算（优化：基于后处理结果）
def calculate_1bit_purity(image):
    img_np = np.array(image.convert("L"))
    total = img_np.size
    pure_pixels = np.sum((img_np == 0) | (img_np == 255))
    purity = (pure_pixels / total) * 100
    return purity

