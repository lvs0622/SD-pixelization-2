# ====================== 工具函数（强化像素感+减少杂色） ======================
def create_output_dir(dir_path):
    import os
    if not os.path.exists(dir_path):
        os.makedirs(dir_path)
    return dir_path

def get_stable_canny(image, low=80, high=160):
    """
    优化：提高Canny阈值+强化边缘，减少噪声，适配像素风格硬边缘
    """
    img_gray = np.array(image.convert("L"))
    img_blur = cv2.GaussianBlur(img_gray, (3, 3), 0)  # 更小模糊核，保留线条细节
    edges = cv2.Canny(img_blur, low, high)
    # 二值化处理：强制边缘只有纯黑/纯白，强化像素硬边
    edges[edges > 0] = 255
    edges = np.expand_dims(edges, axis=2)
    edges = np.repeat(edges, 3, axis=2)
    return Image.fromarray(edges)

def post_process_1bit(image, threshold=127, pixel_size=8):
    """
    先降分辨率，再放大，实现块化像素感
    """
    img_gray = np.array(image.convert("L"))
    # 1. 二值化
    img_1bit = np.where(img_gray > threshold, 255, 0).astype(np.uint8)
    # 2. 降分辨率（关键：强制块化）
    h, w = img_1bit.shape
    small_h, small_w = h // pixel_size, w // pixel_size
    img_small = cv2.resize(img_1bit, (small_w, small_h), interpolation=cv2.INTER_NEAREST)
    # 3. 放大回原尺寸，用最近邻插值保持块化
    img_pixelated = cv2.resize(img_small, (w, h), interpolation=cv2.INTER_NEAREST)
    # 转为RGB
    img_pixelated = np.expand_dims(img_pixelated, axis=2)
    img_pixelated = np.repeat(img_pixelated, 3, axis=2)
    return Image.fromarray(img_pixelated)
